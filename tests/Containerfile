FROM --platform=linux/amd64 cachyos/cachyos:latest

RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm python git curl sudo base-devel paru

# Non-root user with passwordless sudo for realistic testing
RUN useradd -m -G wheel testuser && \
    echo "testuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

COPY --chown=testuser:testuser . /home/testuser/hanzo

USER testuser
WORKDIR /home/testuser/hanzo

RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/home/testuser/.local/bin:${PATH}"
RUN uv tool install ansible-core
RUN ansible-galaxy collection install -r requirements.yml

# Stage 1: --check WITHOUT user config.
#   Exercises: graceful missing-config path (pre_tasks stat → include_vars
#   skipped), git identity injection skipped via `is defined` guards,
#   clone-branch git_adopt (no .dotfiles, no .claude yet).
#   The hardware role is skipped by the container guard
#   (ansible_virtualization_type == 'docker') so no host paths are touched
#   even if /sys/class/dmi/id/product_name bleeds through from the host.
RUN ansible-playbook playbook.yml --check

# Stage 2: --check WITH user config.
#   Exercises: pre_tasks include_vars success path, git identity injection,
#   pull-branch git_adopt (existing .dotfiles, existing .claude/.git).
RUN mkdir -p /home/testuser/.dotfiles/.git && \
    mkdir -p /home/testuser/.claude/.git && \
    mkdir -p /home/testuser/.config/hanzo && \
    printf 'hanzo_fullname: "Test User"\nhanzo_email: "test@example.com"\n' \
      > /home/testuser/.config/hanzo/config.yml && \
    ansible-playbook playbook.yml --check
