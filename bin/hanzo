#!/usr/bin/env bash
# Hanzo CLI wrapper — runs the Ansible provisioner.
# Usage: hanzo [ansible-playbook-args...]
# Examples:
#   hanzo              # full provisioning run
#   hanzo --check      # dry run (shows what would change)

set -euo pipefail

HANZO_DIR="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"

cd "$HANZO_DIR"

exec ansible-playbook playbook.yml "$@"
